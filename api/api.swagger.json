  "paths": {
    "/v1/admin/identity/users": {
      "get": {
        "summary": "ListUsers returns users with optional filtering by status or search query.",
        "operationId": "AdminIdentity_ListUsers",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListUsersResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "default 20, max 100",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "nextPageToken",
            "description": "cursor-based pagination token",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "statusFilter",
            "description": "optional: filter by user status",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "ACTIVE",
              "PENDING_APPROVAL",
              "INACTIVE",
              "SUSPENDED"
            ]
          },
          {
            "name": "searchQuery",
            "description": "optional: search across email/username/name",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "AdminIdentity"
        ]
      }
    },
