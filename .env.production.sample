# ==============================================================================
# Saturn Production Environment Variables Template
# Copy this file to '.env' on your production host (e.g., AWS EC2 instance)
# and customize the secret values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker Container Image Configuration
# ------------------------------------------------------------------------------
# The Docker image tag to deploy (defaults to saturn:latest if not specified)
SATURN_IMAGE=saturn:latest

# ------------------------------------------------------------------------------
# Database Configurations (PostgreSQL)
# ------------------------------------------------------------------------------
# The database username (defaults to 'saturn')
POSTGRES_USER=saturn_prod

# The master database password.
# WARNING: Always change this to a strong, randomly generated password!
POSTGRES_PASSWORD=your_strong_random_db_password_here

# The database name (defaults to 'saturn')
POSTGRES_DB=saturn_prod

# ------------------------------------------------------------------------------
# Routing & Gateway Configuration (Cloudflare Tunnel)
# ------------------------------------------------------------------------------
# The Cloudflare Tunnel token retrieved from the Cloudflare Zero Trust Dashboard.
# This authorizes the outbound 'cloudflared' container to route traffic to the app.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ------------------------------------------------------------------------------
# Saturn Application Override Configurations
# ------------------------------------------------------------------------------
# Log output format: 'json' (recommended for CloudWatch ingestion) or 'text'
SATURN_LOG_FORMAT=json

# Log verbosity level: debug, info, warn, error
SATURN_LOG_LEVEL=info

# JWT claims configurations
SATURN_AUTH_ISSUER=saturn-production
SATURN_AUTH_AUDIENCE=saturn-api-production
